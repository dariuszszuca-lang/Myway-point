rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function hasAuthEmail() {
      return isAuthenticated() && request.auth.token.email is string;
    }

    function authEmail() {
      return request.auth.token.email.lower();
    }

    function signedInUser() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isKnownAdminEmail() {
      return hasAuthEmail() && authEmail() in [
        'dariusz.szuca@gmail.com',
        'krystiannagaba@gmail.com',
        'mywaymarcin@gmail.com',
        'waldemarsikorski77@gmail.com',
        'b.mikolajczewski@wp.pl'
      ];
    }

    function isAdmin() {
      return isAuthenticated() && signedInUser().role == 'admin';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function validUserKeys() {
      return request.resource.data.keys().hasOnly([
        'email',
        'displayName',
        'role',
        'patientId',
        'createdAt'
      ]);
    }

    function validPatientLink() {
      return request.resource.data.patientId == null ||
        get(/databases/$(database)/documents/patients/$(request.resource.data.patientId)).data.email == authEmail();
    }

    function validUserCreate() {
      return hasAuthEmail() &&
        validUserKeys() &&
        request.resource.data.email == authEmail() &&
        (
          (request.resource.data.role == 'admin' &&
            isKnownAdminEmail() &&
            request.resource.data.patientId == null) ||
          (request.resource.data.role == 'patient' && validPatientLink())
        );
    }

    function validOwnerRoleUpdate() {
      return request.resource.data.role == resource.data.role ||
        (
          resource.data.role == 'patient' &&
          request.resource.data.role == 'admin' &&
          isKnownAdminEmail()
        );
    }

    function validOwnerPatientLinkUpdate() {
      return request.resource.data.patientId == resource.data.patientId || validPatientLink();
    }

    function validOwnerUserUpdate() {
      return hasAuthEmail() &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'patientId', 'role']) &&
        validOwnerRoleUpdate() &&
        validOwnerPatientLinkUpdate();
    }

    function validSessionKeys() {
      return request.resource.data.keys().hasOnly([
        'patientId',
        'patientName',
        'therapistId',
        'therapistName',
        'date',
        'startTime',
        'endTime',
        'status',
        'notes',
        'createdAt',
        'updatedAt'
      ]);
    }

    function validBookedSlotKeys() {
      return request.resource.data.keys().hasOnly([
        'sessionId',
        'therapistId',
        'date',
        'startTime',
        'endTime',
        'status',
        'updatedAt'
      ]);
    }

    function bookedSlotMatchesSession(sessionId) {
      let session = getAfter(/databases/$(database)/documents/sessions/$(sessionId)).data;
      return validBookedSlotKeys() &&
        request.resource.data.sessionId == sessionId &&
        request.resource.data.therapistId == session.therapistId &&
        request.resource.data.date == session.date &&
        request.resource.data.startTime == session.startTime &&
        request.resource.data.endTime == session.endTime &&
        request.resource.data.status == session.status;
    }

    function canWriteOwnBookedSlot(sessionId) {
      return isAuthenticated() &&
        getAfter(/databases/$(database)/documents/sessions/$(sessionId)).data.patientId == signedInUser().patientId &&
        bookedSlotMatchesSession(sessionId);
    }

    // USERS - kolekcja użytkowników z rolami
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && validUserCreate();
      allow update: if isAdmin() || (isOwner(userId) && validOwnerUserUpdate());
    }

    // PATIENTS - pacjenci
    match /patients/{patientId} {
      // Admini mają pełny dostęp
      allow read, write: if isAdmin();
      // Pacjent może czytać tylko swój rekord (powiązany przez email lub patientId w users)
      allow read: if isAuthenticated() &&
        ((hasAuthEmail() && resource.data.email == authEmail()) ||
         signedInUser().patientId == patientId);
    }

    // THERAPISTS - terapeuci
    match /therapists/{therapistId} {
      // Wszyscy zalogowani mogą czytać (potrzebne do kalendarza)
      allow read: if isAuthenticated();
      // Tylko admini mogą modyfikować
      allow write: if isAdmin();
    }

    // AVAILABILITY - dostępność terapeutów
    match /availability/{availabilityId} {
      // Wszyscy zalogowani mogą czytać (potrzebne do kalendarza)
      allow read: if isAuthenticated();
      // Tylko admini mogą modyfikować
      allow write: if isAdmin();
    }

    // AVAILABILITY_OVERRIDES - zmiany dostępności terapeutów (edytuj dzień)
    match /availability_overrides/{overrideId} {
      // Wszyscy zalogowani mogą czytać (potrzebne do kalendarza)
      allow read: if isAuthenticated();
      // Tylko admini mogą modyfikować
      allow write: if isAdmin();
    }

    // BOOKED_SLOTS - anonimowe zajęte terminy, bez danych pacjenta
    match /booked_slots/{slotId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || canWriteOwnBookedSlot(slotId);
      allow update: if isAdmin() ||
        (canWriteOwnBookedSlot(slotId) &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']) &&
          request.resource.data.status == 'cancelled');
      allow delete: if isAdmin();
    }

    // SESSIONS - sesje/rezerwacje
    // Walidacja dat (brak dat wstecz, 3 dni min dla pacjentów) — frontend-side
    // Firestore rules nie obsługują porównania stringów dat z request.time
    match /sessions/{sessionId} {
      // Admini mają pełny dostęp
      allow read, write: if isAdmin();
      // Pacjent może czytać tylko swoje pełne rezerwacje
      allow read: if isAuthenticated() && resource.data.patientId == signedInUser().patientId;
      // Pacjent może tworzyć rezerwację tylko dla siebie
      allow create: if isAuthenticated() &&
        validSessionKeys() &&
        request.resource.data.status == 'scheduled' &&
        request.resource.data.patientId == signedInUser().patientId;
      // Pacjent może odwołać swoją własną wizytę (zmiana statusu na 'cancelled')
      allow update: if isAuthenticated() &&
        resource.data.patientId == signedInUser().patientId &&
        request.resource.data.status == 'cancelled' &&
        resource.data.status == 'scheduled' &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt']);
    }
  }
}
